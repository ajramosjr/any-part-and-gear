# Supabase — replace with your actual project values
# Dashboard: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# Supabase Storage base URL (optional, for manual image URL building)
NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://placeholder.supabase.co/storage/v1/object/public

# OpenAI — required for AI vehicle scan feature
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-placeholder
